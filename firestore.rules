rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMember(householdId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    match /users/{uid} {
      // Any authenticated user can read profiles (needed for household members
      // to see each other's names). Only the owner can write their own profile.
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    match /households/{householdId} {
      allow read:   if isMember(householdId);
      allow create: if isSignedIn() &&
                       request.auth.uid in request.resource.data.members;
      allow update: if isMember(householdId) ||
                       // Allow joining via invite: non-member adds themselves
                       // if household has room (< 2 members) and only modifies members field
                       (isSignedIn() &&
                        request.auth.uid in request.resource.data.members &&
                        !(request.auth.uid in resource.data.members) &&
                        resource.data.members.size() < 2 &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      allow delete: if false;

      match /groups/{groupId} {
        allow read, write: if isMember(householdId);
      }

      match /categories/{categoryId} {
        allow read, write: if isMember(householdId);
      }

      match /goals/{goalId} {
        allow read, write: if isMember(householdId);
      }

      match /expenses/{expenseId} {
        allow read:           if isMember(householdId);
        allow create:         if isMember(householdId) &&
                                 request.resource.data.created_by == request.auth.uid;
        allow update, delete: if isMember(householdId);
      }
    }

    match /invite_codes/{code} {
      // Anyone can read an invite code (the code itself is the secret)
      allow read: if true;
      // Only authenticated users can write (handled by app logic)
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}